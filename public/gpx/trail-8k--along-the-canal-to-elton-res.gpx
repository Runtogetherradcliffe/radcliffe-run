 <metadata>
  <name>RTR - Along the canal to Elton Res</name>
  <desc>This route avoids the closed section of the banana path. A nice flat route to and around part of Elton Reservoir. On the way back we'll continue further along the canal and head back to the market via 'Asda Hill'</desc>
  <author>
   <name>Paul Cox</name>
   <link href="https://www.strava.com/athletes/90628842"/>
  </author>
  <copyright author="OpenStreetMap contributors">
   <year>2020</year>
   <license>https://www.openstreetmap.org/copyright</license>
  </copyright>
  <link href="https://www.strava.com/routes/3335652372641939658"/>
 </metadata>
