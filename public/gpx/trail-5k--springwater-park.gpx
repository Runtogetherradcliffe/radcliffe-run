 <metadata>
  <name>RTR - Springwater park</name>
  <desc>Run up Radcliffe New road before turning left into Springwater park. Follow the path through the park and emerge on to Highfield Lane.  Then follow the road as it merges in to Lilly Hill street. At the end of the road turn right on to RNR and run back down the road to the market. </desc>
  <author>
   <name>Paul Cox</name>
   <link href="https://www.strava.com/athletes/90628842"/>
  </author>
  <copyright author="OpenStreetMap contributors">
   <year>2020</year>
   <license>https://www.openstreetmap.org/copyright</license>
  </copyright>
  <link href="https://www.strava.com/routes/3267571547081021606"/>
 </metadata>
